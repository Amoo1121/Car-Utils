{
  "name": "car-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backend:up": "docker compose up -d --build --wait",
    "backend:stop": "docker compose stop",
    "dev": "npm run backend:up && vite",
    "dev:lan": "npm run backend:up && vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "deploy:cloudbase": "npm run build && npx --yes -p @cloudbase/cli tcb hosting deploy dist -e car-utils-sync-d8gc5l3xlb8350cdf",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "^2.27.1",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.9"
  }
}
